@rendermode InteractiveServer

@if (Envelope != null)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Envelope Details</h5>
                    <button type="button" class="close btn btn-lg" @onclick="@Close" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="col row">
                        <div class="col-22 col-sm-8">

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Code:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@Envelope.Code</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Description:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@Envelope.Description</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Envelope URL:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@Envelope.EnvelopeUrl</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Qty in Stock:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@Envelope.QuantityInStock</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Active:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@(Envelope.IsActive ? "Yes" : "No")</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Created on:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@Envelope.CreatedDate.ToShortDateString()</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Created by:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@(Envelope.CreatedBy ?? "-")</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Last modified on:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@(Envelope.LastModifiedDate?.ToShortDateString() ?? "-")</label>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-5 col-form-label text-nowrap pe-4">Last modified by:</label>
                                <div class="col-sm-7 ps-5">
                                    <label class="form-control-plaintext">@(Envelope.LastModifiedBy ?? "-")</label>
                                </div>
                            </div>

                        </div>
                    </div>
                    <button type="button" class="btn btn-outline-primary" @onclick="@Close">Close</button>
                </div>
            </div>
        </div>
    </div>
}
