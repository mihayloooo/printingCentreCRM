@page "/companyadd"
@using PrintingCentre.Management.Application.Features.Companies.Commands.CreateCompany

@rendermode InteractiveServer

@if (!IsSaved)
{
    <section class="employee-edit">

        <h3 class="page-title mb-5">Add New Company</h3>

        <EditForm Enhance Model="Company" OnValidSubmit="@HandleValidSubmit"
                  FormName="AddCompanyForm">

            <FluentValidationValidator />

            <div class="row mb-0">
                <label for="name" class="col-form-label col-md-3">Name: </label>
                <div class="col-md-8">
                    <InputText id="name" class="form-control col-md-8" @bind-Value="@Company.Name" placeholder="Enter company name"></InputText>
                </div>
                <div class="offset-md-3 col-md-8" style="min-height:1.5rem;">
                    <ValidationMessage For="@(() => Company.Name)" />
                </div>
            </div>

            <div class="row mb-0">
                <label for="code" class="col-form-label col-md-3">Code: </label>
                <div class="col-md-8">
                    <InputText id="code" class="form-control col-md-8" @bind-Value="@Company.Code" placeholder="Enter company code"></InputText>
                </div>
                <div class="offset-md-3 col-md-8" style="min-height:1.5rem;">
                    <ValidationMessage For="@(() => Company.Code)" />
                </div>
            </div>

            <div class="row mb-0">
                <label for="logoUrl" class="col-form-label col-md-3">Logo URL: </label>
                <div class="col-md-8">
                    <InputText id="logoUrl" class="form-control col-md-8" @bind-Value="@Company.LogoUrl" placeholder="Enter company logo URL"></InputText>
                </div>
            </div>

            <div class="mt-2">
                <button type="submit" class="btn btn-primary me-1">Add company</button>
            </div>

        </EditForm>

    </section>
}
else
{
    <div class="alert @StatusClass">@Message</div>

    <button type="button" class="btn btn-outline-primary" @onclick="@NavigateToOverview">Back to overview</button>
}
